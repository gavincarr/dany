# .env - dotenv-compatible environment variables
#
# This file is shared and committed to git, so DO NOT use for secrets or local
# settings - those should go in a separate `.env.local`.
#
# As much configuration should go here as possible so that new env vars
# don't break anyone and everyone gets to benefit from improvements.
#
# You can use either `KEY=value` syntax, or `export KEY=value` - there is no
# difference for dotenv libraries, only for shell users loading via `direnv`.
# If you're unsure add the `export`, as it won't break anything.
#
CGO_ENABLED=1
